  "pages": {
    "configuration": {
      "title": "Configuration",
      "description": "Set up your add-on",
      "tabs": [
        {
          "name": "account",
          "title": "Account",
          "table": {
            "header": [
              {
                "field": "name",
                "label": "Account Name"
              },
              {
                "field": "username",
                "label": "Client ID"
              }
            ],
            "actions": ["edit", "delete", "clone"]
          },
          "entity": [
            {
              "field": "name",
              "label": "Account Name",
              "type": "text",
              "required": true,
              "help": "Enter a unique name for this account.",
              "options": {
                "placeholder": "Enter the Account Name here"
              },
              "validators": [
                {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 50,
                  "errorMsg": "Length of Account name should be between 1 and 50"
                },
                {
                  "type": "regex",
                  "pattern": "^[a-zA-Z]\\w*$",
                  "errorMsg": "Account name should not contain whitespace and must start with a letter and followed by alphabetic letters, digits or underscores."
                }
              ]
            },
            {
              "field": "username",
              "label": "Client ID",
              "type": "text",
              "required": true,
              "help": "Enter the Client ID for this account.",
              "options": {
                "placeholder": "Enter the Client ID here"
              },
              "validators": [
                {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 200,
                  "errorMsg": "Length of Client ID should be between 1 and 200"
                }
              ]
            },
            {
              "field": "password",
              "label": "Client Secret",
              "type": "text",
              "encrypted": true,
              "required": true,
              "help": "Enter the Client Secret for this account.",
              "options": {
                "placeholder": "Enter the Client Secret here"
              },
              "validators": [
                {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 8192,
                  "errorMsg": "Length of Client Secret should be between 1 and 8192"
                }
              ]
            },
            {
              "field": "tenant_id",
              "label": "Tenant ID",
              "type": "text",
              "encrypted": false,
              "required": true,
              "help": "It will be overridden when the Tenant ID is provided in inputs or alert actions.",
              "options": {
                "placeholder": "Enter the Tenant ID here"
              },
              "validators": [
                {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 200,
                  "errorMsg": "Length of Tenant ID should be between 1 and 200"
                }
              ]
            },
            {
              "field": "use_delegated_permissions",
              "label": "Use delegated permissions",
              "type": "checkbox",
              "required": false
            },
            {
              "field": "delegated_acc_name",
              "label": "Delegated Access Account Name",
              "type": "text",
              "help": "Enter the unique name of the account that you set up in the helper app",
              "required": false
            }
          ]
        },
        {
          "name": "proxy",
          "title": "Proxy Configuration",
          "entity": [
            {
              "field": "proxy_enabled",
              "label": "Enable Proxy",
              "type": "checkbox"
            },
            {
              "field": "proxy_url",
              "label": "Proxy Host",
              "type": "text",
              "required": true,
              "options": {
                "placeholder": "Required"
              },
              "help": "Hostname of the Proxy server",
              "validators": [
                {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 4096,
                  "errorMsg": "Max host length is 4096"
                },
                {
                  "pattern": "^[a-zA-Z0-9:][a-zA-Z0-9\\.\\-:]+$",
                  "errorMsg": "Proxy Host is invalid",
                  "type": "regex"
                }
              ]
            },
            {
              "field": "proxy_port",
              "label": "Proxy Port",
              "type": "text",
              "required": true,
              "options": {
                "placeholder": "Required"
              },
              "help": "Port to connect to the Proxy server",
              "validators": [
                {
                  "type": "number",
                  "range": [1, 65535]
                },
                {
                  "type": "regex",
                  "errorMsg": "Proxy Port field must be an integer.",
                  "pattern": "^\\d+$"
                }
              ]
            },
            {
              "field": "proxy_username",
              "label": "Proxy Username",
              "type": "text",
              "help": "Username to connect to Proxy server, if any.",
              "validators": [
                {
                  "type": "string",
                  "minLength": 0,
                  "maxLength": 50,
                  "errorMsg": "Max length of username is 50"
                }
              ]
            },
            {
              "field": "proxy_password",
              "label": "Proxy Password",
              "type": "text",
              "encrypted": true,
              "help": "Password to connect to Proxy server, if any.",
              "validators": [
                {
                  "type": "string",
                  "minLength": 0,
                  "maxLength": 8192,
                  "errorMsg": "Max length of password is 8192"
                }
              ]
            }
          ],
          "options": {
            "saveValidator": "function(formData) { if(!formData.proxy_enabled || formData.proxy_enabled === '0') {return true; } if(!formData.proxy_url) { return 'Proxy Host can not be empty'; } if(!formData.proxy_port) { return 'Proxy Port can not be empty'; } return true; }"
          }
        },
        {
          "name": "logging",
          "title": "Logging",
          "entity": [
            {
              "field": "loglevel",
              "label": "Log Level",
              "help": "(DEBUG, INFO, WARNING, ERROR or CRITICAL)",
              "type": "singleSelect",
              "required": true,
              "options": {
                "disableSearch": true,
                "autoCompleteFields": [
                  {
                    "label": "DEBUG",
                    "value": "DEBUG"
                  },
                  {
                    "label": "INFO",
                    "value": "INFO"
                  },
                  {
                    "label": "WARNING",
                    "value": "WARNING"
                  },
                  {
                    "label": "ERROR",
                    "value": "ERROR"
                  },
                  {
                    "label": "CRITICAL",
                    "value": "CRITICAL"
                  }
                ]
              },
              "defaultValue": "INFO"
            }
          ]
        }
      ]
    },
