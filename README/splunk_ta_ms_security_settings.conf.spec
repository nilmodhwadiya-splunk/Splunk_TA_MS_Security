[proxy]
proxy_enabled = [true | false] Whether Proxy server should be used or not for communication
proxy_url = <string> Proxy server address either in IPv4, IPv6 or FQDN format
proxy_port = <string> Port of the Proxy server on which it is listening
proxy_username = <string> Username of the Proxy server if authentication is turned on
proxy_password = <string> Password of the Proxy server if authentication is turned on

[logging]
loglevel = [DEBUG | INFO | WARNING | ERROR | CRITICAL]
